{
    "name": "NVIDIA GPU Dev",
    "image": "ultralytics/ultralytics:latest",
    
    "containerEnv": {
        "UV_SYSTEM_PYTHON": "1"
    },

    "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | INSTALLER_NO_MODIFY_PATH=1 sh && cp $HOME/.local/bin/uv /usr/local/bin/uv && uv pip install --system -e .",
    
    "mounts": [
        "source=uv-cache-nvidia,target=/root/.cache/uv,type=volume"
    ],
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "charliermarsh.ruff"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "python.analysis.extraPaths": ["./backend"],
                "python.terminal.activateEnvironment": false
            }
        }
    },
    "runArgs": [
        "--gpus", "all",
        "--shm-size=8gb"
    ]
}
